# Django
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=incidentiq
MONGODB_INCIDENTS_COLLECTION=incidents
# Vector index must target embedding with 3072 dimensions for gemini-embedding-001.
MONGODB_VECTOR_INDEX=incidents_vector_index

# Gemini (google-generativeai SDK)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_KEY_2=your-backup-gemini-api-key
GEMINI_API_KEY_3=your-second-backup-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
